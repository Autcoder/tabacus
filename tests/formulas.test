
TEST: The Gaussian Distribution at x=1
RUN:
1 / sqrt(2pi) * e^(-1^2 / 2)
EXPECT_STDOUT:
0.24197072451914337

TEST: The Black-Scholes Formula
RUN:
(ln(100 / 95) + (0.05^2 / 2)) / sqrt(1)
EXPECT_STDOUT:
0.05254329438755048

TEST: Great-Circle Distance (Haversine Formula)
RUN:
sin(0.5)^2 + cos(0.2)cos(0.8)sin(0.3)^2
EXPECT_STDOUT:
0.2894809239881009

TEST: Relativity: Kinetic Energy at 90% Light Speed
RUN:
1(1^2) (1 / sqrt(1 - 0.9^2) - 1)
EXPECT_STDOUT:
1.294157338705618

TEST: Wave Interference
RUN:
2cos(pi / 3)sin(pi / 6)
EXPECT_STDOUT:
0.5

TEST: Lorentz Factor
RUN:
1 / sqrt(1 - 0.99^2)
EXPECT_STDOUT:
7.088812050083354

TEST: Simple Pendulum Period
RUN:
2pi sqrt(1 / 9.81)
EXPECT_STDOUT:
2.0060666807106475

TEST: Standard Normal Distribution Peak
RUN:
1 / sqrt(2pi)
EXPECT_STDOUT:
0.3989422804014327

TEST: Entropy Expression
RUN:
-(0.25ln(0.25) + 0.75ln(0.75))
EXPECT_STDOUT:
0.5623351446188083

TEST: Damped Oscillation
RUN:
e^(-0.5)cos(2pi)
EXPECT_STDOUT:
0.6065306597126334

TEST: Euclidean Distance
RUN:
sqrt((5 - 1)^2 + (7 - 2)^2)
EXPECT_STDOUT:
6.4031242374328485

TEST: Continuous Compound Interest
RUN:
100e^(0.05 * 10)
EXPECT_STDOUT:
164.87212707001282