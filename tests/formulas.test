TEST: The Gaussian Distribution at x=1
RUN:
1 / sqrt(2pi) * euler^(-1^2 / 2)
EXPECT_STDOUT:
0.24197072451914337

TEST: The Black-Scholes Formula
RUN:
(ln(100 / 95) + (0.05^2 / 2)) / sqrt(1)
EXPECT_STDOUT:
0.05254329438755048

TEST: Great-Circle Distance (Haversine Formula)
RUN:
sin(0.5)^2 + cos(0.2)cos(0.8)sin(0.3)^2
EXPECT_STDOUT:
0.2894809239881009

TEST: Relativity: Kinetic Energy at 90% Light Speed
RUN:
1(1^2) (1 / sqrt(1 - 0.9^2) - 1)
EXPECT_STDOUT:
1.294157338705618

TEST: Wave Interference
RUN:
2cos(pi / 3)sin(pi / 6)
EXPECT_STDOUT:
0.5

TEST: Lorentz Factor
RUN:
1 / sqrt(1 - 0.99^2)
EXPECT_STDOUT:
7.088812050083354

TEST: Simple Pendulum Period
RUN:
2pi sqrt(1 / 9.81)
EXPECT_STDOUT:
2.0060666807106475

TEST: Standard Normal Distribution Peak
RUN:
1 / sqrt(2pi)
EXPECT_STDOUT:
0.3989422804014327

TEST: Entropy Expression
RUN:
-(0.25ln(0.25) + 0.75ln(0.75))
EXPECT_STDOUT:
0.5623351446188083

TEST: Damped Oscillation
RUN:
euler^(-0.5)cos(2pi)
EXPECT_STDOUT:
0.6065306597126334

TEST: Euclidean Distance
RUN:
sqrt((5 - 1)^2 + (7 - 2)^2)
EXPECT_STDOUT:
6.4031242374328485

TEST: Continuous Compound Interest
RUN:
100euler^(0.05 * 10)
EXPECT_STDOUT:
164.87212707001282

TEST: Arrhenius Equation (Reaction Rate Constant)
RUN:
10^11 * euler^(-75000 / (8.314 * 300))
EXPECT_STDOUT:
0.008727067950862156

TEST: Barometric Formula (Atmospheric Pressure at Altitude)
RUN:
101325 * (1 - 0.0065 * 2500 / 288.15)^5.2558
EXPECT_STDOUT:
74682.86361964639

TEST: Gravitational Potential Energy / Escape Velocity
RUN:
sqrt(2 * 6.674e-11 * 5.972e24 / 6371000)
EXPECT_STDOUT:
11185.72649237147

TEST: Radar Range Equation (Signal Power Received)
RUN:
(1000 * 100 * 100 * 1^2 * 10) / ((4pi)^3 * 10000^4)
EXPECT_STDOUT:
5.0393022551874215e-12

TEST: Relativistic Doppler Effect
RUN:
sqrt((1 - 0.8) / (1 + 0.8))
EXPECT_STDOUT:
0.33333333333333326

TEST: Ideal Gas Law (Volume of 1 mole at STP)
RUN:
(1 * 8.3144626 * 273.15) / 101325
EXPECT_STDOUT:
0.02241396949607698

TEST: Annuity Payment Formula (Mortgage Calculation)
RUN:
300000 * (0.05 / 12) * (1 + 0.05 / 12)^360 / ((1 + 0.05 / 12)^360 - 1)
EXPECT_STDOUT:
1610.4648690364193

TEST: Shannon-Hartley Theorem (Data Channel Capacity in Bits/Sec)
RUN:
1000000 * log2(1 + 10^(20 / 10))
EXPECT_STDOUT:
6658211.482751795

TEST: Stefan-Boltzmann Law (Radiation Power)
RUN:
5.670374e-8 * 1.5 * 1000^4
EXPECT_STDOUT:
85055.61

TEST: Relativistic Mass Energy (Rest + Kinetic Energy at 0.6c)
RUN:
1 * (3e8)^2 / sqrt(1 - 0.6^2)
EXPECT_STDOUT:
1.125e+17